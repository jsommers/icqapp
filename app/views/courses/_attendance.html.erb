<% if @course.attendance_today %>
  <% if @checked_in %>
    <p>You're checked in for today</p>
  <% else %>
    <%= link_to "Attendance check-in", attendance_check_in_path(@course), :method => :post, :class => 'btn btn-primary' %>
  <% end %>
<% else %>
  <p>Attendance check-in is not open</p>
<% end %>

